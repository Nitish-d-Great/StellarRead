# ── Stellar ──────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ── Publisher wallet (receives x402 USDC) ───────────────────────
# Must add a Change Trust for testnet USDC (issuer GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5)
# or Soroban transfer simulation fails with "Trustline entry is missing" on this account.
PUBLISHER_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Facilitator (pick ONE model) ────────────────────────────────
# A) Hosted facilitator (recommended — matches oceans404 / OpenZeppelin Channels guide)
#    Generate API key: curl https://channels.openzeppelin.com/testnet/gen
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
FACILITATOR_API_KEY=
# Optional: force mode — http | local
# X402_FACILITATOR_MODE=http

# B) In-process facilitator (self-hosted; your key sponsors Soroban fees)
#    Set X402_FACILITATOR_MODE=local if you also have FACILITATOR_URL in .env but want local.
# FACILITATOR_STELLAR_PRIVATE_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Pricing (x402 exact scheme uses Soroban USDC; PRICE_PER_BATCH is in USD) ──
PRICE_PER_BATCH=0.10
# Payers need testnet USDC in Freighter (not just XLM). See Stellar x402 docs.
ARTICLES_PER_BATCH=10

# ── News API ───────────────────────────────────────────────────
# fmp = Financial Modeling Prep (crypto-latest by default; needs FMP_API_KEY)
# coindesk_rss = no key
# cryptocompare = needs CRYPTOCOMPARE_API_KEY
NEWS_SOURCE=fmp
FMP_API_KEY=
# Optional: override endpoint (default: crypto-latest)
# FMP_NEWS_URL=https://financialmodelingprep.com/stable/news/stock-latest

CRYPTOCOMPARE_API_KEY=
COINDESK_RSS_URL=https://www.coindesk.com/arc/outboundfeeds/rss/

# ── Server ─────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
